rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: normalize Gmail (remove dots, strip +tag) for robust email match
    function normalizeEmail(email) {
      let lower = (email + "").lower().trim();
      let parts = lower.split("@");
      let local = parts.size() > 0 ? parts[0] : "";
      let domain = parts.size() > 1 ? "@" + parts[1] : "";
      let plusIndex = local.indexOf("+");
      let localNoPlus = plusIndex >= 0 ? local.substring(0, plusIndex) : local;
      // We no longer remove dots in Rules because rules do not support global replace or join().
      let normalizedDomain = (domain == "@googlemail.com") ? "@gmail.com" : domain;
      return localNoPlus + normalizedDomain;
    }

    function isAdmin(tripId) {
      let doc = get(/databases/$(database)/documents/trips/$(tripId)).data;
      let authed = request.auth != null;
      let hasEmail = authed && request.auth.token.email != null;
      let userEmail = hasEmail ? normalizeEmail(request.auth.token.email) : "";
      return authed && (
        doc.adminUid == request.auth.uid ||
        (hasEmail && doc.adminEmail != null && normalizeEmail(doc.adminEmail) == userEmail)
      );
    }

    function getCollab(tripId) {
      let doc = get(/databases/$(database)/documents/trips/$(tripId)).data;
      let hasEmail = request.auth != null && request.auth.token.email != null;
      let normalized = hasEmail ? normalizeEmail(request.auth.token.email) : "";
      let key1 = normalized.replace(".", "_").replace(".", "_").replace(".", "_");
      let collabs = doc.collaborators;
      
      return (hasEmail && collabs != null) ? (
        collabs[normalized] != null ? collabs[normalized] :
        collabs[key1] != null ? collabs[key1] :
        collabs[normalized.lower()] != null ? collabs[normalized.lower()] : null
      ) : null;
    }

    function isCollaborator(tripId) {
      return request.auth != null && getCollab(tripId) != null;
    }

    function hasPermission(tripId, tab, level) {
      let collab = getCollab(tripId);
      return collab != null && (
        collab.permissions[tab] == level
        || (level == 'read' && collab.permissions[tab] == 'write')
      );
    }

    // Trips Collection
    match /trips/{tripId} {
      allow read: if true;
      allow write: if request.auth != null && (
        !exists(/databases/$(database)/documents/trips/$(tripId))
        || isAdmin(tripId)
        || (
          request.resource.data.adminEmail != null
          && request.auth.token.email != null
          && normalizeEmail(request.resource.data.adminEmail) == normalizeEmail(request.auth.token.email)
        )
      );

      // --- SUBCOLLECTIONS ---

      match /checklistItems/{itemId} {
        allow read, write: if isAdmin(tripId);
      }

      match /days/{dayId} {
        allow read: if isAdmin(tripId) || hasPermission(tripId, 'planner', 'read');
        allow write: if isAdmin(tripId) || hasPermission(tripId, 'planner', 'write');
      }
      match /places/{placeId} {
        allow read: if isAdmin(tripId) || hasPermission(tripId, 'planner', 'read');
        allow write: if isAdmin(tripId) || hasPermission(tripId, 'planner', 'write');
      }

      match /flights/{flightId} {
        allow read: if isAdmin(tripId) || hasPermission(tripId, 'flights', 'read');
        allow write: if isAdmin(tripId) || hasPermission(tripId, 'flights', 'write');
      }

      match /hotels/{hotelId} {
        allow read: if isAdmin(tripId) || hasPermission(tripId, 'hotels', 'read');
        allow write: if isAdmin(tripId) || hasPermission(tripId, 'hotels', 'write');
      }

      match /tickets/{ticketId} {
        allow read: if isAdmin(tripId) || hasPermission(tripId, 'tickets', 'read');
        allow write: if isAdmin(tripId) || hasPermission(tripId, 'tickets', 'write');
      }

      match /budgetItems/{itemId} {
        allow read: if isAdmin(tripId) || isCollaborator(tripId);
        allow write: if isAdmin(tripId);
      }

      match /resources/{resourceId} {
        allow read: if isAdmin(tripId) || hasPermission(tripId, 'resources', 'read');
        allow write: if isAdmin(tripId) || hasPermission(tripId, 'resources', 'write');
      }

      match /notes/{noteId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
      match /attachments/{attachId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null;
      }
    }
  }
}
